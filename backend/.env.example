PORT=5000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ecommerce
DB_CONNECTION_LIMIT=10
# DB SSL options
# DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA_PATH=/etc/secrets/ca.pem
# DB_SSL_CA=
# DB_SSL_CA_BASE64=

JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=1d
JWT_COOKIE_MAX_AGE_MS=86400000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
# COOKIE_DOMAIN=

# Comma-separated list. Leave blank to allow all origins in local/dev.
CORS_ORIGIN=http://localhost:5173

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=futuremart

# Optional script helpers
API_BASE_URL=http://localhost:5000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password

# OTP / Email verification
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_WINDOW_MS=900000
OTP_RATE_LIMIT_MAX=30

# Email provider options: console | resend | brevo
# - console: logs OTP code in backend terminal (dev fallback)
# - resend: uses RESEND_API_KEY + EMAIL_FROM
# - brevo: uses BREVO_API_KEY + EMAIL_FROM
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@futuremart.com
RESEND_API_KEY=
BREVO_API_KEY=
