NODE_ENV=production
PORT=5000

DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=10

JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=1d
JWT_COOKIE_MAX_AGE_MS=86400000

# For separate frontend/backend domains, keep these values:
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
# COOKIE_DOMAIN=

# Comma-separated allowed frontend origins.
# Example: https://futuremart.pages.dev,https://futuremart.com
CORS_ORIGIN=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=futuremart

OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_WINDOW_MS=900000
OTP_RATE_LIMIT_MAX=30

# Email provider options: console | resend | brevo
EMAIL_PROVIDER=resend
EMAIL_FROM=no-reply@futuremart.com
RESEND_API_KEY=
BREVO_API_KEY=
